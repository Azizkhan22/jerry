# Groq LLM
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_ALLOWED_USER_ID=your_telegram_numeric_user_id

# Google (Gmail / Calendar / Tasks)
GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json
GOOGLE_TOKEN_PATH=credentials/google_token.json

# Attendance portal
ATTENDANCE_PORTAL_URL=https://your-portal.example.com/login
ATTENDANCE_USERNAME=your_username
ATTENDANCE_PASSWORD=your_password

# General
TIMEZONE=Asia/Karachi
USER_NAME=Syed
